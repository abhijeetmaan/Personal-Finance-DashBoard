PORT=5000
NODE_ENV=development
# Either name works (Render / Atlas often use MONGODB_URI)
MONGO_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/dbname
# MONGODB_URI=mongodb+srv://...

# Comma-separated browser origins (Vercel URL). Required in production.
CLIENT_URL=http://localhost:5173

# Optional legacy name (used if CLIENT_URL is unset)
# CORS_ORIGIN=http://localhost:5173
