PORT=5000
NODE_ENV=development
# Either name works (Render / Atlas often use MONGODB_URI)
MONGO_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/dbname
# MONGODB_URI=mongodb+srv://...

# Comma-separated browser origins. Local dev hosts are always allowed.
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app

# Extra origins (optional). Set to 0 to allow only CLIENT_URL + locals (no *.vercel.app wildcard).
# CORS_ALLOW_VERCEL_SUBDOMAINS=0

# Optional additional comma-separated origins
# CORS_EXTRA_ORIGINS=https://preview-123.vercel.app

# Optional legacy name (used if CLIENT_URL is unset)
# CORS_ORIGIN=http://localhost:5173
