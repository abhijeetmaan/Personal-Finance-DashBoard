# Public API origin (no trailing slash, no /api/v1). Production: https://your-service.onrender.com
VITE_API_URL=http://localhost:5000

# Optional: override Socket.IO URL (defaults to same origin as VITE_API_URL)
# VITE_SOCKET_URL=http://localhost:5000

# Legacy: full base including /api/v1 — still supported if VITE_API_URL is unset
# VITE_API_BASE_URL=http://localhost:5000/api/v1
